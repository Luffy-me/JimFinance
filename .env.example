# JimFinance Environment Configuration

# Database
DATABASE_URL=******localhost:5432/jimfinance
DATABASE_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379

# Security
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# OAuth
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret
GOOGLE_OAUTH_REDIRECT_URL=http://localhost:8000/api/auth/callback/google

# AI Services
GEMINI_API_KEY=your-gemini-api-key
GROQ_API_KEY=your-groq-api-key
OPENAI_API_KEY=your-openai-api-key

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_WEBHOOK_URL=https://yourdomain.com/telegram/webhook

# Google Sheets Integration
GOOGLE_SHEETS_CREDENTIALS=path/to/google-sheets-credentials.json
SHEETS_SPREADSHEET_ID=your-spreadsheet-id

# Application Settings
APP_NAME=JimFinance
APP_VERSION=0.1.0
DEBUG=false
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
LOG_LEVEL=INFO

# OCR
OCR_ENGINE=tesseract
TESSERACT_PATH=/usr/bin/tesseract

# Email
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SENDER_EMAIL=noreply@jimfinance.com

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
